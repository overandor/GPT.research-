# Main poster behavior
POSTER_ENV=development

# Stripe Checkout
# Use sk_test_... until you have verified full flow and webhook handling.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_MODE=payment
STRIPE_SUCCESS_URL=https://example.com/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://example.com/cancel
STRIPE_CLIENT_REFERENCE_PREFIX=poster
STRIPE_QUANTITY=1
STRIPE_ALLOW_PROMOTION_CODES=false
STRIPE_BILLING_ADDRESS_COLLECTION=
STRIPE_CUSTOMER_EMAIL=

# Stripe webhook verifier
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_WEBHOOK_HOST=0.0.0.0
STRIPE_WEBHOOK_PORT=8080
STRIPE_WEBHOOK_LOG=stripe_webhook_events.jsonl

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X API v2
X_BEARER_TOKEN=
X_API_BASE=https://api.x.com

# Reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=multi-platform-poster/1.0
REDDIT_SUBREDDIT=
REDDIT_KIND=self

# Pinterest
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=SELF_ONLY
TIKTOK_IS_AIGC=true
